NODE_ENV=development

# Porta do BFF Web
PORT=3000

# URLs dos microsserviços
IDENTITY_SERVICE_URL=http://localhost:5001
PATIENT_SERVICE_URL=http://localhost:5002
APPOINTMENT_SERVICE_URL=http://localhost:5003
MEDICAL_RECORD_SERVICE_URL=http://localhost:5004

# Chave JWT (mesma do Identity Service)
JWT_CHAVE=chave-desenvolvimento-minimo-32-caracteres

# Chave HMAC compartilhada com os microsserviços
HMAC_CHAVE=chave-hmac-compartilhada-com-o-bff

# Redis (cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka (invalidação de cache + SSE em tempo real)
# Deixar vazio para desabilitar o consumer (desenvolvimento sem Docker)
KAFKA_BROKERS=localhost:9092

# Origins permitidas para CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3002
