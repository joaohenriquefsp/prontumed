# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# ─────────────────────────────────────────────────────
# PostgreSQL — credenciais compartilhadas entre todos os bancos (dev)
# ─────────────────────────────────────────────────────
POSTGRES_USER=clinicos
POSTGRES_PASSWORD=prontumed_secret

# ─────────────────────────────────────────────────────
# Identity Service — JWT
# ─────────────────────────────────────────────────────
JWT_SECRET=super_secret_key_troque_em_producao
JWT_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# ─────────────────────────────────────────────────────
# BFF — HMAC para comunicação interna com os serviços
# ─────────────────────────────────────────────────────
HMAC_SECRET=hmac_secret_key_troque_em_producao
