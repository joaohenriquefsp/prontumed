{
  "name": "medical-outbox-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "postgres-medical",
    "database.port": "5432",
    "database.user": "clinicos",
    "database.password": "prontumed_secret",
    "database.dbname": "db_medical_records",
    "topic.prefix": "clinicos",
    "slot.name": "medical_outbox_slot",
    "plugin.name": "pgoutput",
    "table.include.list": "public.eventos_saida",
    "heartbeat.interval.ms": "5000",

    "transforms": "outbox",
    "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
    "transforms.outbox.route.by.field": "tipo_agregado",
    "transforms.outbox.route.topic.replacement": "prontumed.${routedByValue}",
    "transforms.outbox.table.field.event.id": "id",
    "transforms.outbox.table.field.event.key": "id_agregado",
    "transforms.outbox.table.field.event.type": "tipo_evento",
    "transforms.outbox.table.field.event.payload": "payload",
    "transforms.outbox.table.field.event.timestamp": "criado_em",
    "transforms.outbox.table.fields.additional.placement": "tipo_evento:header:eventType",

    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.storage.StringConverter"
  }
}
